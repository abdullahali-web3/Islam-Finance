{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/core/*": [
        "./core/*"
      ],
      "@/features/*": [
        "./features/*"
      ],
      "@/components/*": [
        "./components/*"
      ],
      "@/schemas/*": [
        "./schemas/*"
      ],
      "@/store/*": [
        "./store/*"
      ],
      "@/services/*": [
        "./services/*"
      ],
      "@/db/*": [
        "./db/*"
      ],
      "@/locales/*": [
        "./locales/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "nativewind-env.d.ts"
  ],
  "exclude": [
    "node_modules",
    "proxy"
  ]
}